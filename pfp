<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Miden PFP Generator 🚀</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <div class="container">
    <h1>Miden PFP Generator 🚀</h1>
    <p>Upload your image to generate a Miden-style astronaut PFP</p>

    <input type="file" id="upload" accept="image/*">

    <div class="preview-box">
      <img id="preview" />
      <div class="overlay"></div>
    </div>

    <button onclick="generatePFP()">Generate PFP</button>
    <button onclick="downloadPFP()">Download</button>

    <p id="status"></p>
  </div>

  <script src="app.js"></script>
</body>
</html>

body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: radial-gradient(circle at top, #0b0f1f, #05060a);
  color: white;
  text-align: center;
}

.container {
  margin-top: 40px;
}

h1 {
  color: #00ffcc;
}

.preview-box {
  position: relative;
  width: 260px;
  height: 260px;
  margin: 20px auto;
  border-radius: 20px;
  overflow: hidden;
  border: 2px solid #00ffcc;
}

#preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0,255,204,0.2), rgba(0,0,0,0.6));
  pointer-events: none;
}

button {
  margin: 10px;
  padding: 10px 18px;
  border: none;
  cursor: pointer;
  background: #00ffcc;
  font-weight: bold;
  border-radius: 8px;
}

button:hover {
  background: #00c2a3;
}

#status {
  margin-top: 10px;
  color: #aaa;
}

const upload = document.getElementById("upload");
const preview = document.getElementById("preview");
const status = document.getElementById("status");

let imageLoaded = false;

upload.addEventListener("change", function () {
  const file = upload.files[0];
  if (file) {
    preview.src = URL.createObjectURL(file);
    imageLoaded = true;
    status.innerText = "Image loaded ✔";
  }
});

function generatePFP() {
  if (!imageLoaded) {
    status.innerText = "Please upload an image first.";
    return;
  }

  status.innerText = "Applying Miden astronaut style 🚀...";
  
  setTimeout(() => {
    status.innerText = "PFP ready! Looks Miden-style ✨";
  }, 1500);
}

function downloadPFP() {
  if (!imageLoaded) {
    status.innerText = "Nothing to download yet.";
    return;
  }

  const link = document.createElement("a");
  link.href = preview.src;
  link.download = "miden-pfp.png";
  link.click();
}
